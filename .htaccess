RewriteEngine On

# If request is for an existing file/directory, serve directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# If the request already has .php extension, stop rewriting
RewriteCond %{REQUEST_URI} \.php$ [NC]
RewriteRule ^ - [L]

# Otherwise, add .php if the .php file exists
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*?)/?$ $1.php [L]

# Shortcuts
RewriteRule ^$ login.php [L]
RewriteRule ^login/?$ login.php [L]
RewriteRule ^dashboard/?$ dashboard.php [L]